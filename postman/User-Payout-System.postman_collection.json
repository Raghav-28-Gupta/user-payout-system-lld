    {
      "name": "5. Withdrawals - 24h Gate & Failed-Payout Recovery (Question 2)",
      "description": "Reserves Rs 50 on withdraw, simulates a processor FAILURE (money credited back, retry allowed immediately), then a COMPLETED withdrawal which starts the 24h lock.",
      "item": [
        {
          "name": "Withdraw Rs 50",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{runUser}}/withdraw",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{runUser}}",
                "withdraw"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 201\", function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.test(\"payout is PENDING\", function () { pm.expect(body.status).to.eql(\"PENDING\"); });",
                  "pm.collectionVariables.set(\"withdrawPayoutId1\", body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Balance After Reserve (expect Rs 30.00)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{runUser}}/balance",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{runUser}}",
                "balance"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"balance is 30.00\", function () { pm.expect(pm.response.json().withdrawableBalance).to.eql(\"30.00\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Resolve Withdrawal as FAILED (simulates processor failure)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
