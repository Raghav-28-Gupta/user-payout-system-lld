              "raw": "{\n  \"status\": \"approved\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"adjustment is 36.00\", function () { pm.expect(pm.response.json().adjustment).to.eql(\"36.00\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Reconcile Sale 3 -> Approved (adjustment Rs 36.00)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/sales/{{saleId3}}/reconcile",
