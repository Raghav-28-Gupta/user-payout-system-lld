              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "payouts",
                "{{withdrawPayoutId1}}",
                "resolve"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"failed\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
