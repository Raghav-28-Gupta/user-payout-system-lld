        },
        {
          "name": "Get Balance After Reconciliation (expect Rs 80.00 = Rs 12 + Rs 68)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{runUser}}/balance",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{runUser}}",
                "balance"
              ]
            },
            "description": "This is the assignment's own acceptance number: -4 + 36 + 36 = Rs 68 final payout, on top of the Rs 12 advance already paid = Rs 80 total balance."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"balance is 80.00 (Rs12 advance + Rs68 final payout)\", function () { pm.expect(pm.response.json().withdrawableBalance).to.eql(\"80.00\"); });"
                ]
